<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | URL Shortener</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
            text-decoration: none;
            /* overflow-x: hidden; */
            /* overflow-y: hidden; */
        }
        body{
            background-color: violet;
            width: 100vw;
            /* height: 100vh; */
        }
        table,tr,th,td{
            border: 1px solid black;
            border-collapse: collapse;
        }
        td{
            padding: .2rem 2rem;
        }
        .wrapper{
            width: 100%;
            /* height: 100%; */
        }
        .container{
            width: 100%;
            /* height: 100%; */
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }
        h1{
            text-align: center;
            margin-top: 4rem;

        }
        h3{
            text-align: center;
            margin-top: 4rem;
            margin-bottom: 4rem;
        }
        button{
            padding: .5rem 2rem;
            margin-bottom: 2rem;
        }
        button{
            cursor: pointer;
        }
    </style>
</head>
<body>
    <!-- if user is loggedIn show Dashboard -->
        <div class="wrapper">
            <h1>URL Shortener</h1>
            <h3>Welcome <%= user.name %> !</h3>
            <div class="container">
                <div>
                    <a href="/createUrl">
                        <button>Create Short URL</button>
                    </a>
                </div>
                <%if (locals.user) {%>
                    <div class="dashboard">
                        
                        <table>
                            <thead>
                                <tr>
                                    <th>Original URL</th>
                                    <th>Short URL</th>
                                </tr>
                            </thead>
                            <tbody>
                            <%urls.forEach(url => {%>
                                <tr>
                                    <td><%= url.redirectUrl %></td>
                                    <td><a href="localhost:4000/url/<%= url.shortId %>" target="_blank">localhost:4000/url/<%= url.shortId %></a></td>
                                </tr>
                            <%});%>
                            </tbody>
                        </table>
                    </div>
                <%}%>
               
            </div>
        </div>
    <!-- Dashboard Ends -->

</body>
</html>